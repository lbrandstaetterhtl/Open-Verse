# ============================================================
# Open-Verse Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- NETWORK CONFIGURATION ---
PORT=5000
HOST=0.0.0.0
# (Docker only) Host port that maps to the container's port 5000
APP_PORT=5000

# --- DATABASE CONFIGURATION ---
# Set to 'false' for PostgreSQL (recommended for Docker/production)
USE_SQLITE=false

# --- PostgreSQL (Docker Compose) ---
# These are used by both the 'db' container and the 'app' container.
POSTGRES_DB=openverse
POSTGRES_USER=openverse
POSTGRES_PASSWORD=change-me-to-a-strong-password

# (Alternative) Full connection string – set this instead of the above if you
# are connecting to an external database (e.g. Neon, Supabase, RDS).
# When using docker-compose the DATABASE_URL is built automatically from the
# POSTGRES_* variables above, so you can leave this blank.
DATABASE_URL=

# --- SQLite (local development only) ---
# Set USE_SQLITE=true and optionally provide a custom path.
# SQLITE_PATH=/var/lib/open-verse/data.db

# --- SECURITY & AUTH ---
# Required for session encryption. Generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 'true' if the app is behind a reverse proxy (Nginx, Traefik, etc.)
TRUST_PROXY=true

# --- EXTERNAL SERVICES (optional) ---
# SendGrid API key for email verification
SENDGRID_API_KEY=SG.your-key-here
# Groq API key for AI features
GROQ_API_KEY=gsk_your-key-here
