# --- NETWORK CONFIGURATION ---
PORT=5000
HOST=0.0.0.0

# --- DATABASE CONFIGURATION ---
# Set to 'true' to use better-sqlite3
USE_SQLITE=true
# (Optional) Absolute path to sqlite file. Defaults to 'local.db' in project root
SQLITE_PATH=/var/lib/open-verse/data.db

# (Optional) Neon/PostgreSQL connection string. Required if USE_SQLITE=false
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- SECURITY & AUTH ---
# Required for session encryption. Generate a strong random string.
SESSION_SECRET=create-a-strong-random-secret-here
# Set to 'true' or '1' if the app is behind a reverse proxy (Nginx, etc.)
TRUST_PROXY=false

# --- EXTERNAL SERVICES ---
# (Optional) SendGrid API key for email verification
SENDGRID_API_KEY=SG.your-key-here
# (Optional) Groq API key for AI features
GROQ_API_KEY=gsk_your-key-here
