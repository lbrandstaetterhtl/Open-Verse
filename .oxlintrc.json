{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript"
  ],
  "categories": {
    "correctness": "warn",
    "perf": "off",
    "suspicious": "off",
    "pedantic": "off",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**"
  ]
}
