{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript"
  ],
  "categories": {
    "correctness": "deny",
    "perf": "warn",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": "deny",
    "typescript/no-unused-vars": "deny",
    "react/no-array-index-key": "deny",
    "react/jsx-no-duplicate-props": "deny"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**"
  ]
}
