{
  "name": "open-verse",
  "description": "Osiris - An open social universe for sharing stories, ideas, and connecting across diverse communities.",
  "version": "0.1.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch --env-file=.env server/index.ts",
    "build": "powershell -ExecutionPolicy Bypass -File scripts/compliance-audit.ps1 -Fix",
    "build:quick": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "compliance:check": "powershell -ExecutionPolicy Bypass -File scripts/compliance-audit.ps1 -SkipBuild",
    "compliance:fix": "powershell -ExecutionPolicy Bypass -File scripts/compliance-audit.ps1 -Fix -SkipBuild",
    "lint:strict": "oxlint --config .oxlintrc.json",
    "lint:fix": "oxlint --config .oxlintrc.json --fix",
    "knip": "knip",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "seed": "tsx --env-file=.env scripts/seed-testdata.ts",
    "seed:test": "tsx --env-file=.env scripts/seed-testdata.ts",
    "db:push": "drizzle-kit push",
    "db:sync": "tsx --env-file=.env scripts/db-sync.ts",
    "db:repair": "tsx --env-file=.env scripts/db-repair.ts",
    "db:health": "tsx --env-file=.env scripts/db-health.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
